# ============================================================
# Alerte Déneigement — Variables d'environnement
# Copier vers .env et remplir les valeurs
# ============================================================

# --- API Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- Base de données ---
DB_PATH=./data/alerte.db

# --- Planif-Neige Data ---
# Unofficial JSON API (default — no token needed)
PLANIF_NEIGE_JSON_URL=https://raw.githubusercontent.com/ludodefgh/planif-neige-public-api/main/data/planif-neige.json
GEOBASE_MAP_URL=https://raw.githubusercontent.com/ludodefgh/planif-neige-public-api/main/data/geobase-map.json

# Official API (optional — contact donneesouvertes@montreal.ca for a token)
# PLANIF_NEIGE_TOKEN=your_token_here
# PLANIF_NEIGE_WSDL=https://servicesenligne2.ville.montreal.qc.ca/api/infoneige/InfoneigeWebService

# --- Cron ---
POLL_INTERVAL_MINUTES=2
T60_CHECK_INTERVAL_MINUTES=5

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,https://alertedeneigement.ca

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# --- Monitoring (optional) ---
SENTRY_DSN=

# ============================================================
# Mobile App (.env.local in apps/mobile)
# ============================================================

# API URL for mobile app
EXPO_PUBLIC_API_URL=http://localhost:3000

# EAS Project ID (from expo.dev after running "eas init")
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id