{
  "name": "alerte-deneigement",
  "version": "1.0.0",
  "private": true,
  "description": "Alertes gratuites de déneigement — Montréal",
  "workspaces": [
    "apps/mobile",
    "apps/web",
    "services/api"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=services/api",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build:api": "npm run build --workspace=services/api",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
